# MBL Catering — serve index.html as the folder's default page
# (Apache / cPanel / most shared hosting). Lets https://fbws.tw/mbl_catering/
# open the app without typing index.html.
DirectoryIndex index.html

# Make sure UTF-8 is declared so English + 繁體中文 render correctly
AddDefaultCharset utf-8
AddCharset utf-8 .html .css .js .json .svg

# Always fetch index.html fresh so new ?v= asset versions are picked up.
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # The main fbws.tw site sends a Content-Security-Policy whose connect-src does
  # not include Supabase, which blocks the app's cloud database calls. Remove the
  # inherited policy for this folder and set one that allows Supabase + the CDNs.
  Header always unset Content-Security-Policy
  Header unset Content-Security-Policy
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://mmmjpkkvqfjegyawrisg.supabase.co wss://mmmjpkkvqfjegyawrisg.supabase.co https://cdn.jsdelivr.net https://fbws.tw https://www.fbws.tw; object-src 'none'; base-uri 'self'"
</IfModule>
