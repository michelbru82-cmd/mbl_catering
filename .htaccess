# MBL Catering — serve index.html as the folder's default page
# (Apache / cPanel / most shared hosting). Lets https://fbws.tw/mbl_catering/
# open the app without typing index.html.
DirectoryIndex index.html

# Make sure UTF-8 is declared so English + 繁體中文 render correctly
AddDefaultCharset utf-8
AddCharset utf-8 .html .css .js .json .svg
